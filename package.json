{
  "name": "ambassador",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.25.0",
  "scripts": {
    "dev": "next dev -p 7171",
    "build": "next build",
    "start": "next start",
    "lint": "pnpm lint:js && pnpm lint:ts && pnpm lint:css && pnpm lint:html",
    "lint:js": "eslint . --cache --cache-location .eslintcache --ext .js,.jsx,.cjs,.mjs",
    "lint:ts": "eslint . --cache --cache-location .eslintcache --ext .ts,.tsx,.cts,.mts",
    "lint:ts:type-aware": "eslint . --cache --cache-location .eslintcache-type-aware --ext .ts,.tsx,.cts,.mts -c eslint.type-aware.config.mjs",
    "lint:css": "stylelint \"src/**/*.css\" --cache --cache-location .stylelintcache",
    "lint:html": "files=$(find public src -type f \\( -name '*.html' -o -name '*.htm' \\) -print 2>/dev/null); if [ -n \"$files\" ]; then pnpm exec html-validate $files; else echo 'No HTML files found. Skipping HTML lint.'; fi",
    "type-check": "rm -rf .next/types .next/dev/types && pnpm exec next typegen && pnpm exec tsc --noEmit",
    "prune:css": "pnpm build && purgecss --css \".next/**/*.css\" --content \"src/**/*.{ts,tsx}\" --content \"src/**/*.css\" --output .next/purgecss"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1026.0",
    "@hackclub/icons": "^0.2.1",
    "@tailwindcss/postcss": "^4.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "jose": "^6.2.2",
    "jsqr": "^1.4.0",
    "jszip": "^3.10.1",
    "lucide-react": "^1.7.0",
    "next": "16.2.6",
    "next-intl": "^4.9.1",
    "pdf-lib": "^1.17.1",
    "postcss": "^8.5.8",
    "postgres": "^3.4.9",
    "postgres-shift": "^0.1.0",
    "qrcode": "^1.5.4",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "shadcn": "^4.1.2",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "html-validate": "^10.11.3",
    "purgecss": "^8.0.0",
    "stylelint": "^17.6.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^5",
    "yaml-eslint-parser": "^2.0.0"
  }
}
